{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "sessions": {
      "title": "Chat Session",
      "description": "A single chat conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "userId", "title", "timestamp"]
    },
    "messages": {
      "title": "Message",
      "description": "A message within a chat session",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["sessionId", "userId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile data"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "sessions",
      "description": "User chat sessions"
    },
    "/users/{userId}/sessions/{sessionId}/messages/{messageId}": {
      "schema": "messages",
      "description": "Messages within a session"
    }
  }
}
